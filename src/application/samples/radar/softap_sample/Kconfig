menu "RADAR SoftAP Sample Configuration"

config WIFI_SSID
    string "Set WIFI SSID"
    default "my_softAP"
    help
        Configure the WiFi SSID for the RADAR SoftAP hotspot.

config WIFI_PWD
    string "Set WIFI password"
    default "123456789"
    help
        Configure the WiFi password (pre-shared key) for the RADAR SoftAP hotspot.

endmenu
