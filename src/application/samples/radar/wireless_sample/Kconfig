menu "RADAR WIRELESS Sample Configuration"

config WIFI_SSID
    string "Set WIFI SSID"
    default "my_softAP"
    help
        Configure the target WiFi SSID for RADAR WIRELESS STA connection.

config WIFI_PWD
    string "Set WIFI password"
    default "123456789"
    help
        Configure the WiFi password (pre-shared key) for RADAR WIRELESS STA connection.

endmenu
