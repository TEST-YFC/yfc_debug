menu "SLP WIRELESS Sample Configuration"

config WIFI_SSID
    string "Set WIFI SSID"
    default "my_softAP"
    help
        Configure the target WiFi SSID for SLP WIRELESS STA connection.

config WIFI_PWD
    string "Set WIFI password"
    default "123456789"
    help
        Configure the WiFi password (pre-shared key) for SLP WIRELESS STA connection.

config PC_OUT_NUM
    int
    prompt "cfg PC_OUT_NUM"
    range 30 60
    default 48

config RADAR_ANT_PAIR_NUM
    int
    prompt "cfg RADAR_ANT_PAIR_NUM"
    range 1 4
    default 4

endmenu
